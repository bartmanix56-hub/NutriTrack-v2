rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Fonction helper pour vérifier si l'utilisateur est admin
    function isAdmin() {
      return request.auth != null && request.auth.uid == 'qEuqSbWO73OwTEwL6LhEILS5djD2';
    }

    // Collection users - Admin peut tout lire, utilisateurs peuvent lire/écrire leurs propres données
    match /users/{userId} {
      allow read: if isAdmin() || (request.auth != null && request.auth.uid == userId);
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Collection feedbacks - Tous les utilisateurs authentifiés peuvent créer, admin peut tout lire/modifier
    match /feedbacks/{feedbackId} {
      allow read: if isAdmin();
      allow create: if request.auth != null;
      allow update, delete: if isAdmin();
    }

    // Collection aliments_communs - Lecture publique pour tous, admin peut écrire
    match /aliments_communs/{alimentId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Collection admin_logs - Seulement admin peut lire/écrire
    match /admin_logs/{logId} {
      allow read, write: if isAdmin();
    }
  }
}
