rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Bibliothèque commune d'aliments
    match /aliments_communs/{barcode} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // 2. Documents utilisateurs à la racine (pour le panel admin)
    match /users/{userId} {
      // Admin peut lire tous les documents users pour le panel admin
      allow read: if request.auth != null &&
                     (request.auth.uid == "qEuqSbWO73OwTEwL6LhEILS5djD2" || request.auth.uid == userId);
      // Admin peut modifier tous les documents (pour migrations), sinon chaque user modifie le sien
      allow write: if request.auth != null &&
                      (request.auth.uid == "qEuqSbWO73OwTEwL6LhEILS5djD2" || request.auth.uid == userId);
    }

    // 3. Journal personnel et aliments perso de l'utilisateur (sous-collections)
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // 4. Système de Feedback sécurisé
    match /feedbacks/{document=**} {
      // Tout le monde peut envoyer un feedback (même non connecté)
      allow create: if true;

      // SEUL TOI peux lire, modifier (marquer comme lu) ou supprimer les feedbacks
      allow read, update, delete: if request.auth != null && request.auth.uid == "qEuqSbWO73OwTEwL6LhEILS5djD2";
    }

    // 5. Logs admin (pour le panel admin)
    match /admin_logs/{logId} {
      allow read, write: if request.auth != null && request.auth.uid == "qEuqSbWO73OwTEwL6LhEILS5djD2";
    }
  }
}
